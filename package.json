{
  "name": "castle",
  "version": "1.0.0",
  "private": true,
  "main": "dist-electron/main.js",
  "author": "Castle",
  "description": "Launcher moderno para Windows com busca, biblioteca e integração com aplicativos",
  "license": "MIT",
  "scripts": {
    "prepare": "husky install",
    "dev": "concurrently -k \"vite --port 5173 --strictPort\" \"tsc -p tsconfig.electron.json -w\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "electron .",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron && electron-builder --publish=never",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\"",
    "format": "prettier --write ."
  },
  "build": {
    "appId": "com.example.castle",
    "productName": "Castle",
    "artifactName": "Castle-Setup-${version}.${ext}",
    "files": [
      "dist/**",
      "dist-electron/**",
      "icones/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icones/castle.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Castle"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://example.com/castle-updates"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.0.0",
    "concurrently": "^7.0.0",
    "electron": "^26.6.10",
    "electron-builder": "^25.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^13.0.0",
    "postcss": "^8.0.0",
    "prettier": "^2.0.0",
    "tailwindcss": "^3.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.1.0",
    "vite": "^5.0.0",
    "wait-on": "^6.0.0"
  },
  "dependencies": {
    "clsx": "^1.2.1",
    "electron-store": "^8.0.0",
    "electron-updater": "^6.8.9",
    "framer-motion": "^10.12.16",
    "lucide-react": "^0.268.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.0",
    "react-window": "^1.8.11"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write",
      "git add"
    ]
  }
}
